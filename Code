  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 19,
  }).addTo(map);

  // Animate zoom to user location
  setTimeout(() => {
    map.flyTo([lat, lng], zoom, { duration: 2.2, easeLinearity: 0.15 });
  }, 300);

  // Add user location marker
  setTimeout(() => {
    addUserMarker(lat, lng);
    renderSpots();
  }, 2600);
