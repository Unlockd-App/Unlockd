    ]},
    { color: '#5a8f6a', pts: [
      [-120,50],[-95,50],[-78,43],[-70,43],[-65,42],[-70,37],[-80,28],[-87,20],[-80,15],[-75,10],[-78,5],[-75,0],[-80,-5],[-80,-10],[-75,-15],[-70,-20],[-65,-30],[-68,-40],[-65,-50],[-62,-55],[-68,-55],[-75,-45],[-80,-35],[-80,-25],[-80,-15],[-88,-5],[-83,3],[-80,8],[-72,12],[-65,18],[-85,22],[-90,28],[-103,30],[-110,28],[-118,32],[-120,35],[-122,40],[-125,48],[-120,50]
    ]},
    // South America
    { color: '#5a8f6a', pts: [
      [-75,12],[-60,15],[-50,5],[-35,-5],[-35,-15],[-40,-20],[-45,-25],[-50,-30],[-52,-35],[-55,-40],[-65,-55],[-68,-55],[-65,-50],[-62,-40],[-60,-30],[-60,-25],[-58,-18],[-60,-10],[-68,-5],[-78,2],[-78,8],[-75,12]
    ]},
    // Europe
    { color: '#4a7a5e', pts: [
      [-10,36],[0,38],[10,44],[20,48],[30,48],[38,48],[36,55],[30,60],[25,65],[18,70],[10,70],[0,65],[-5,60],[-10,55],[-10,48],[-10,42],[-10,36]
    ]},
    // Scandinavia
    { color: '#4a7a5e', pts: [
      [5,58],[10,57],[15,58],[18,62],[25,68],[28,72],[22,72],[18,70],[14,65],[10,62],[8,60],[5,58]
    ]},
    // Africa
    { color: '#5d8c55', pts: [
      [-18,15],[-10,20],[0,22],[15,22],[30,22],[38,20],[42,12],[48,10],[42,5],[38,-2],[36,-8],[36,-18],[32,-28],[28,-35],[22,-40],[18,-35],[15,-28],[12,-20],[8,-10],[2,-5],[0,0],[-2,5],[-8,12],[-18,15]
    ]},
    // Asia (main body)
    { color: '#4d7d5c', pts: [
      [28,72],[38,70],[55,72],[70,72],[90,70],[110,72],[130,70],[140,65],[145,58],[135,48],[128,38],[120,30],[110,22],[100,14],[90,10],[80,18],[70,22],[60,22],[50,28],[40,38],[38,45],[30,50],[25,55],[25,65],[28,72]
    ]},
    // Arabian Peninsula
    { color: '#4d7d5c', pts: [
      [38,28],[50,28],[60,22],[58,14],[55,10],[48,12],[42,12],[38,18],[38,28]
    ]},
    // Indian Subcontinent
    { color: '#4d7d5c', pts: [
      [68,22],[78,22],[82,18],[80,12],[78,8],[72,8],[68,12],[65,18],[68,22]
    ]},
    // Southeast Asia
    { color: '#4d7d5c', pts: [
      [100,22],[105,18],[108,12],[105,8],[100,10],[95,12],[95,18],[100,22]
    ]},
    // Australia
    { color: '#5a8060', pts: [
      [114,-22],[120,-20],[128,-18],[135,-18],[140,-20],[145,-25],[148,-35],[145,-40],[138,-38],[130,-32],[125,-28],[118,-25],[114,-22]
    ]},
    // Greenland
    { color: '#6a9080', pts: [
      [-55,60],[-42,62],[-25,68],[-18,75],[-20,82],[-35,84],[-50,82],[-62,78],[-65,72],[-55,66],[-55,60]
    ]},
    // Japan
    { color: '#4d7d5c', pts: [
      [130,32],[132,34],[136,36],[140,40],[142,44],[140,44],[136,40],[132,36],[128,34],[130,32]
    ]},
    // UK/Ireland rough
    { color: '#4a7a5e', pts: [
      [-6,50],[-2,50],[2,52],[0,56],[-4,58],[-6,54],[-6,50]
    ]},
  ];

  function latLonToXY(lat, lon, tilt, rotAngle) {
    const phi   = (90 - lat) * Math.PI / 180;
    const theta = (lon + rotAngle) * Math.PI / 180;
    // 3D coords on unit sphere
    let x = Math.sin(phi) * Math.cos(theta);
    let y = Math.cos(phi);
    let z = Math.sin(phi) * Math.sin(theta);
    // Apply tilt (rotation around X axis)
    const cosT = Math.cos(tilt), sinT = Math.sin(tilt);
    const y2 = y * cosT - z * sinT;
    const z2 = y * sinT + z * cosT;
    return { x, y: y2, z: z2 };
  }

  function drawGlobe(rot) {
    ctx.clearRect(0, 0, W, H);
    const tilt = 23.5 * Math.PI / 180; // Earth's axial tilt

    // ── Ocean base ──────────────────────────
    const oceanGrad = ctx.createRadialGradient(cx-30, cy-30, 5, cx, cy, R);
    oceanGrad.addColorStop(0,   '#1a6699');
    oceanGrad.addColorStop(0.3, '#0d4d80');
    oceanGrad.addColorStop(0.7, '#083d6b');
    oceanGrad.addColorStop(1,   '#041e42');
    ctx.beginPath();
    ctx.arc(cx, cy, R, 0, Math.PI*2);
    ctx.fillStyle = oceanGrad;
    ctx.fill();

    // ── Draw continents ───────────────────
    continents.forEach(cont => {
      const projected = cont.pts.map(([lon, lat]) => {
        const p = latLonToXY(lat, lon, tilt, rot * 180 / Math.PI);
        return { ...p, screenX: cx + p.x * R, screenY: cy - p.y * R };
      });

      // Check if mostly visible (z > 0 = front hemisphere)
      const avgZ = projected.reduce((s,p) => s + p.z, 0) / projected.length;
      if (avgZ < -0.2) return;

      ctx.beginPath();
      let first = true;
      projected.forEach(p => {
        if (first) { ctx.moveTo(p.screenX, p.screenY); first = false; }
        else ctx.lineTo(p.screenX, p.screenY);
      });
      ctx.closePath();

      // Clip to circle
      ctx.save();
      ctx.beginPath(); ctx.arc(cx, cy, R, 0, Math.PI*2); ctx.clip();

      // Shade based on z-depth (lighting from upper-left)
      const lit = Math.max(0, Math.min(1, avgZ * 1.2 + 0.15));
      const baseH = cont.color;
      ctx.globalAlpha = 0.55 + lit * 0.45;
      ctx.fillStyle = cont.color;
      ctx.fill();

      // Subtle land highlight edge
      ctx.globalAlpha = 0.12;
      ctx.strokeStyle = '#90c878';
      ctx.lineWidth = 0.8;
      ctx.stroke();

      ctx.restore();
    });

    // ── Ice caps ──────────────────────────
    // North pole
    ctx.save();
    ctx.beginPath(); ctx.arc(cx, cy, R, 0, Math.PI*2); ctx.clip();
    const npPts = [];
    for (let lon = 0; lon <= 360; lon += 10) {
      const p = latLonToXY(75, lon, tilt, rot * 180/Math.PI);
      npPts.push({ screenX: cx + p.x*R, screenY: cy - p.y*R, z: p.z });
    }
    ctx.beginPath();
    let first = true;
    npPts.forEach(p => {
      if (first) { ctx.moveTo(p.screenX, p.screenY); first=false; }
      else ctx.lineTo(p.screenX, p.screenY);
    });
    ctx.closePath();
    ctx.fillStyle = 'rgba(220,235,255,0.65)';
    ctx.fill();
    ctx.restore();

    // South pole
    ctx.save();
    ctx.beginPath(); ctx.arc(cx, cy, R, 0, Math.PI*2); ctx.clip();
    const spPts = [];
    for (let lon = 0; lon <= 360; lon += 10) {
      const p = latLonToXY(-65, lon, tilt, rot * 180/Math.PI);
      spPts.push({ screenX: cx + p.x*R, screenY: cy - p.y*R, z: p.z });
    }
    ctx.beginPath();
    first = true;
    spPts.forEach(p => {
      if (first) { ctx.moveTo(p.screenX, p.screenY); first=false; }
      else ctx.lineTo(p.screenX, p.screenY);
    });
    ctx.closePath();
    ctx.fillStyle = 'rgba(220,235,255,0.55)';
    ctx.fill();
    ctx.restore();

    // ── Lighting: dark side shadow ─────────
    const shadowGrad = ctx.createRadialGradient(cx+40, cy+20, R*0.1, cx+60, cy+40, R*1.1);
    shadowGrad.addColorStop(0,   'rgba(0,0,0,0)');
    shadowGrad.addColorStop(0.4, 'rgba(0,0,0,0)');
    shadowGrad.addColorStop(0.75,'rgba(0,5,20,0.35)');
    shadowGrad.addColorStop(1,   'rgba(0,5,20,0.75)');
    ctx.save();
    ctx.beginPath(); ctx.arc(cx, cy, R, 0, Math.PI*2); ctx.clip();
    ctx.fillStyle = shadowGrad;
    ctx.beginPath(); ctx.arc(cx, cy, R, 0, Math.PI*2); ctx.fill();
    ctx.restore();

    // ── Specular highlight (sunlight glint) ─
    const specGrad = ctx.createRadialGradient(cx-38, cy-38, 2, cx-28, cy-28, R*0.7);
    specGrad.addColorStop(0,   'rgba(255,255,255,0.22)');
    specGrad.addColorStop(0.25,'rgba(255,255,255,0.08)');
    specGrad.addColorStop(1,   'rgba(255,255,255,0)');
    ctx.save();
    ctx.beginPath(); ctx.arc(cx, cy, R, 0, Math.PI*2); ctx.clip();
    ctx.fillStyle = specGrad;
    ctx.beginPath(); ctx.arc(cx, cy, R, 0, Math.PI*2); ctx.fill();
    ctx.restore();

    // ── Thin edge atmosphere rim ───────────
    const rimGrad = ctx.createRadialGradient(cx, cy, R-4, cx, cy, R+3);
    rimGrad.addColorStop(0,   'rgba(100,180,255,0)');
    rimGrad.addColorStop(0.5, 'rgba(100,180,255,0.18)');
    rimGrad.addColorStop(1,   'rgba(100,180,255,0)');
    ctx.beginPath();
    ctx.arc(cx, cy, R+1, 0, Math.PI*2);
    ctx.strokeStyle = rimGrad;
    ctx.lineWidth = 5;
    ctx.stroke();
  }

  function animate() {
    angle += 0.003;
    drawGlobe(angle);
    requestAnimationFrame(animate);
  }
  animate();
})();
</script>

