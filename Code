<script>
(function() {
  // ── Star field ──────────────────────────
  const starCanvas = document.getElementById('stars-canvas');
  function resizeStars() {
    const phone = document.getElementById('phone');
    starCanvas.width  = phone.offsetWidth;
    starCanvas.height = phone.offsetHeight;
    drawStars();
  }
  function drawStars() {
    const ctx = starCanvas.getContext('2d');
    const W = starCanvas.width, H = starCanvas.height;
    ctx.clearRect(0,0,W,H);
    const rng = mulberry32(42);
    for (let i = 0; i < 220; i++) {
      const x = rng() * W;
      const y = rng() * H;
      const r = rng() * 1.2 + 0.2;
      const a = rng() * 0.7 + 0.3;
      ctx.beginPath();
      ctx.arc(x, y, r, 0, Math.PI*2);
      ctx.fillStyle = `rgba(255,255,255,${a})`;
      ctx.fill();
    }
  }
  function mulberry32(seed) {
    return function() {
      seed |= 0; seed = seed + 0x6D2B79F5 | 0;
      let t = Math.imul(seed ^ seed >>> 15, 1 | seed);
      t = t + Math.imul(t ^ t >>> 7, 61 | t) ^ t;
      return ((t ^ t >>> 14) >>> 0) / 4294967296;
    };
  }
  resizeStars();

  // ── Globe rendering ──────────────────────
  const gc = document.getElementById('globe-canvas');
  const ctx = gc.getContext('2d');
  const W = 260, H = 260, R = 118, cx = 130, cy = 130;
  let angle = 0;

  // Continent data: array of polygons in [lon, lat] degrees
  // Accurate simplified continent outlines
  const continents = [
    // North America
    { color: '#4a7c59', pts: [
