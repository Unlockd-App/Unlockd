  { id:4, name:"Biergarten Tübinger Str.", cat:"🍺 Bar", catKey:"bar",
    lat:48.768, lng:9.174,
    photo:"https://images.unsplash.com/photo-1436076863939-06870fe779c2?w=500&q=80",
    note:"Versteckter Biergarten. Donnerstagabends fast immer Platz.",
    author:"Luca D.", av:"LD", color:"#fd79a8", privacy:"public", likes:21 },
];

const FRIENDS = [
  { name:"Mia Köhler",   av:"MK", color:"#e17055", spots:8,  mutual:3 },
  { name:"Jonas Ritter", av:"JR", color:"#00b894", spots:15, mutual:7 },
  { name:"Sophie Lang",  av:"SL", color:"#6c5ce7", spots:5,  mutual:2 },
  { name:"Luca Decker",  av:"LD", color:"#fd79a8", spots:22, mutual:10 },
  { name:"Finn Braun",   av:"FB", color:"#fdcb6e", spots:3,  mutual:1 },
];

const CATS = ["☕ Café","🥘 Food","🍺 Bar","🌆 Aussicht","🎨 Kultur","🏃 Sport"];
const CAT_KEYS = {  "☕ Café":"cafe","🥘 Food":"food","🍺 Bar":"bar","🌆 Aussicht":"view","🎨 Kultur":"art","🏃 Sport":"sport" };

// ═══════════════════════════════════════
// STATE
// ═══════════════════════════════════════
let map, markers = [], userMarker, spots = [...SPOTS];
let selectedPrivacy = "friends", selectedCat = "", currentSpotId = null, isLiked = false;
let userLat = null, userLng = null;

// ═══════════════════════════════════════
// INTRO → MAP
// ═══════════════════════════════════════
function startLocating() {
  const btn = document.getElementById('btn-locate');
  btn.innerHTML = `<span class="locating-dots"><span>•</span><span>•</span><span>•</span></span>`;
  btn.style.background = 'rgba(82,183,136,0.4)';
  btn.disabled = true;

  // Try real geolocation, fallback to Stuttgart
  if (navigator.geolocation) {
    navigator.geolocation.getCurrentPosition(
      pos => launchMap(pos.coords.latitude, pos.coords.longitude, 15),
      ()  => launchMap(48.775, 9.178, 14), // Stuttgart fallback
      { timeout: 5000 }
    );
  } else {
    setTimeout(() => launchMap(48.775, 9.178, 14), 1200);
  }
}

function launchMap(lat, lng, zoom) {
  userLat = lat; userLng = lng;

  // Show map screen
  document.getElementById('screen-intro').classList.add('hidden');
  const mapScreen = document.getElementById('screen-map');
  mapScreen.classList.add('visible');

  // Init Leaflet map
  map = L.map('map', {
    center: [48.0, 10.0], // start wide
    zoom: 5,
