html: `<div style=" background:${spot.color}; border-radius:50% 50% 50% 0; transform:rotate(-45deg); width:38px;height:38px; display:flex;align-items:center;justify-content:center; box-shadow:0 4px 14px rgba(0,0,0,0.28); border:2.5px solid white; cursor:pointer; "><span style="transform:rotate(45deg);font-size:12px;font-weight:700;color:white">${spot.av[0]}</span></div>`,
iconSize: [38,38],
iconAnchor: [19,38],
});
const m = L.marker([spot.lat, spot.lng], { icon }).addTo(map);
m.on(‘click’, () => openSpotCard(spot.id));
markers.push(m);
});
}

function openSpotCard(id) {
