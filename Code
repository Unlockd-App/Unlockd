           </div>
           <style>@keyframes ripple{0%{transform:translate(-50%,-50%) scale(1);opacity:0.8}100%{transform:translate(-50%,-50%) scale(2.5);opacity:0}}</style>`,

```
iconSize: [18,18],
iconAnchor: [9,9],
```

});
userMarker = L.marker([lat, lng], { icon }).addTo(map);
}

// ═══════════════════════════════════════
// SPOTS
// ═══════════════════════════════════════
function renderSpots(filter = ‘all’) {
markers.forEach(m => map.removeLayer(m));
